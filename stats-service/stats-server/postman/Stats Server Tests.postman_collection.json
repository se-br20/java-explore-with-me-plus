    {
      "name": "GET /stats - Вся статистика",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Response contains expected data\", function () {",
              "    const response = pm.response.json();",
              "    ",
              "    const event1 = response.find(item => item.uri === \"/events/1\");",
              "    pm.expect(event1).to.exist;",
              "    pm.expect(event1.app).to.equal(\"ewm-main-service\");",
              "    pm.expect(event1.hits).to.equal(2);",
              "    ",
              "    const event2 = response.find(item => item.uri === \"/events/2\");",
              "    pm.expect(event2).to.exist;",
              "    pm.expect(event2.hits).to.equal(1);",
              "    ",
              "    const actuator = response.find(item => item.uri === \"/actuator/health\");",
              "    pm.expect(actuator).to.exist;",
              "    pm.expect(actuator.app).to.equal(\"stats-server\");",
              "    pm.expect(actuator.hits).to.equal(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/stats?start=2026-02-25 00:00:00&end=2026-02-25 23:59:59",
